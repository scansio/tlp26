{
  "autoCompactEnabled": true,
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx eslint --fix $CLAUDE_FILE_PATHS 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": ["Bash(git *)", "Bash(npm *)", "Bash(npx *)", "Bash(cd *)"]
  },
  "worktree": {
    "symlinkDirectories": ["node_modules"]
  }
}
