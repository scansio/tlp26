# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:pass@localhost:54322/tlp26

# Clerk authentication (required)
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# AES-256-GCM key for encrypting exchange API keys (required)
EXCHANGE_KEY_ENCRYPTION_SECRET=your-32-byte-hex-secret

# CryptoPanic news API (optional, falls back to CoinGecko)
CRYPTOPANIC_API_TOKEN=

# Coinglass funding rates + liquidation data (optional)
COINGLASS_API_KEY=

# AI provider selection — change AI_PROVIDER to switch all agents at once.
# Each provider reads its model from {PROVIDER}_MODEL automatically.
AI_PROVIDER=groq   # groq | cerebras | openai | anthropic | google | mistral

# Model per provider — only the one matching AI_PROVIDER is used
GROQ_MODEL=llama-3.3-70b-versatile
CEREBRAS_MODEL=gpt-oss-120b
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
GOOGLE_MODEL=gemini-2.0-flash
MISTRAL_MODEL=mistral-small-latest

# Provider API keys — only the one matching AI_PROVIDER is required
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
MISTRAL_API_KEY=

# Mastra Cloud trace export (optional)
MASTRA_CLOUD_ACCESS_TOKEN=
