# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:pass@localhost:5432/tlp26

# Clerk authentication (required)
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# AES-256-GCM key for encrypting exchange API keys (required)
EXCHANGE_KEY_ENCRYPTION_SECRET=your-32-byte-hex-secret

# CryptoPanic news API (optional, falls back to CoinGecko)
CRYPTOPANIC_API_TOKEN=

# Coinglass funding rates + liquidation data (optional)
COINGLASS_API_KEY=

# Mastra Cloud trace export (optional)
MASTRA_CLOUD_ACCESS_TOKEN=
